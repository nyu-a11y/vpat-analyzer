}

/*******************************************************
 * AI INTERPRETATION FUNCTIONALITY
 *******************************************************/

/**
 * Main function to interpret conformance levels using AI
 * Processes only rows that were populated in the last extraction run
 * @param {boolean} skipPrompt - If true, automatically processes all rows without prompting
 */
function interpretConformanceLevels(skipPrompt) {
  const ui = SpreadsheetApp.getUi();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(CONFIG.OUTPUT_SHEET_NAME);

  if (!sheet) {
    throw new Error(
      `Output sheet "${CONFIG.OUTPUT_SHEET_NAME}" not found. Please create it with the required columns.`,
    );
  }

  try {
    // Step 1: Validate columns exist
    const columnMap = validateAndMapColumnsForInterpretation(sheet);

    // Step 2: Get the prompt and confidence threshold from Prompts sheet
    const systemPrompt = getPromptFromSheet(ss);
    const confidenceThreshold = getConfidenceThreshold(ss);

    // Step 3: Get row range (skip prompt if automated)
    let userConfig;
    if (skipPrompt) {
      // Automated mode: process all rows
      userConfig = { startRow: null, endRow: null };
    } else {
      // Manual mode: ask user
      userConfig = getRowRangeForInterpretation(ui);
      if (!userConfig) {
        return { success: false, reason: "cancelled" };
      }
    }

    // Determine row range
    let startRow = userConfig.startRow;
    let endRow = userConfig.endRow;

    if (startRow === null || endRow === null) {
      const lastRow = sheet.getLastRow();
      startRow = (columnMap._headerRow || CONFIG.DEFAULT_START_ROW - 1) + 1;
      endRow = lastRow;
    }

    // Step 4: Find rows with original conformance data (from extraction)
    showProgress(`Analyzing ${endRow - startRow + 1} rows...`);
    const rowsToProcess = findRowsWithConformanceData(
      sheet,
      columnMap,
      startRow,
      endRow,
    );

    if (rowsToProcess.length === 0) {
      SpreadsheetApp.getActiveSpreadsheet().toast(
        "No rows with conformance data found. Run extraction first.",
        "No Data",
        5,
      );
      return { success: false, reason: "no-data" };
    }

    // Step 5: Process each row with AI
    showProgress(`Interpreting ${rowsToProcess.length} rows with AI...`);
    const results = processRowsWithAI(
      sheet,
      columnMap,
      rowsToProcess,
      systemPrompt,
      confidenceThreshold,
    );

    if (results.success === 0) {
      SpreadsheetApp.getActiveSpreadsheet().toast(
        "AI interpretation didn't update any rows.",
        "Nothing Processed",
        10,
      );
      return { success: false, reason: "no-updates", results: results };
    }

    // Step 6: Show completion
    const message = `✓ Interpreted ${results.success} of ${rowsToProcess.length} rows`;
    SpreadsheetApp.getActiveSpreadsheet().toast(message, "Success", 10);
    return { success: true, results: results };
  } catch (error) {
    Logger.log(`Error in interpretConformanceLevels: ${error.message}`);
    Logger.log(error.stack);
    SpreadsheetApp.getActiveSpreadsheet().toast(
      `Error: ${error.message}`,
      "Interpretation Failed",
      10,
    );
    return { success: false, reason: "error", message: error.message };
  } finally {
    hideProgress();
  }
}

/**
 * Gets row range from user for interpretation
 */
function getRowRangeForInterpretation(ui) {
  const response = ui.prompt(
    "AI Interpretation Configuration",
    "Enter row range to interpret (optional):\n\n" +
      "Start Row, End Row\n\n" +
      "Examples:\n" +
      "  2, 50  (interpret rows 2-50)\n" +
      "  (leave empty to interpret all rows)",
    ui.ButtonSet.OK_CANCEL,
  );

  if (response.getSelectedButton() !== ui.Button.OK) {
    return null;
  }

  const input = response.getResponseText().trim();

  // If empty, process all rows
  if (!input) {
    return { startRow: null, endRow: null };
  }

  const inputs = input.split(",").map((s) => s.trim());
  const startRow = parseInt(inputs[0], 10);
  const endRow = parseInt(inputs[1], 10);

  if (
    isNaN(startRow) ||
    isNaN(endRow) ||
    startRow < CONFIG.DEFAULT_START_ROW ||
    endRow < startRow
  ) {
    throw new Error("Invalid row numbers.");
  }

  return { startRow, endRow };
}

/**
 * Validates that interpreted columns exist in the sheet
 */
function validateAndMapColumnsForInterpretation(sheet) {
  const allRows = sheet
    .getRange(1, 1, sheet.getLastRow(), sheet.getLastColumn())
    .getValues();

  // Find the header row by scanning for the Criteria column
  let headerRow = null;
  let headerRowIndex = -1;
  for (let r = 0; r < allRows.length; r++) {
    if (allRows[r].includes(CONFIG.COLUMN_NAMES.CRITERIA)) {
      headerRow = allRows[r];
      headerRowIndex = r + 1; // 1-based sheet row
      break;
    }
  }

  if (!headerRow) {
    throw new Error(
      `Could not find header row containing "${CONFIG.COLUMN_NAMES.CRITERIA}" in any row of the sheet.`,
    );
  }

  Logger.log(`Found header row at sheet row ${headerRowIndex}`);
  const columnMap = {};
  columnMap._headerRow = headerRowIndex; // Store for callers to use as data start reference

  // --- Required input columns (read during interpretation) ---
  const requiredColumns = {
    CRITERIA: CONFIG.COLUMN_NAMES.CRITERIA,
    CONFORMANCE_LEVEL: CONFIG.COLUMN_NAMES.CONFORMANCE_LEVEL,
    REMARKS: CONFIG.COLUMN_NAMES.REMARKS,
  };

  // --- Required output columns (written during interpretation) ---
  const requiredOutputColumns = {
    AI_COMMENT: CONFIG.COLUMN_NAMES.AI_COMMENT,
    CONFORMANCE_INTERPRETED: CONFIG.COLUMN_NAMES.CONFORMANCE_INTERPRETED,
    APPLIES_TO_MEDIUMS: CONFIG.COLUMN_NAMES.APPLIES_TO_MEDIUMS,
  };

  // --- Optional columns (mapped if present, silently skipped if absent) ---
  const optionalColumnDefs = {
    INTERNAL_COMMENT: CONFIG.COLUMN_NAMES.INTERNAL_COMMENT,
  };

  // Map required input columns — throw if any are missing
  for (const [key, columnName] of Object.entries(requiredColumns)) {
    const colIndex = headerRow.indexOf(columnName);
    if (colIndex === -1) {
      throw new Error(
        `Required column "${columnName}" not found in sheet headers (checked row ${headerRowIndex}).`,
      );
    }
    columnMap[key] = colIndex + 1;
  }

  // Map required output columns — throw if any are missing
  for (const [key, columnName] of Object.entries(requiredOutputColumns)) {
    const colIndex = headerRow.indexOf(columnName);
    if (colIndex === -1) {
      throw new Error(
        `Required output column "${columnName}" not found in sheet headers (checked row ${headerRowIndex}). Please add this column to the sheet.`,
      );
    }
    columnMap[key] = colIndex + 1;
  }

  // Map optional columns — warn and skip if absent
  for (const [key, columnName] of Object.entries(optionalColumnDefs)) {
    const colIndex = headerRow.indexOf(columnName);
    if (colIndex !== -1) {
      columnMap[key] = colIndex + 1;
      Logger.log(
        `Optional column "${columnName}" found at column ${colIndex + 1}.`,
      );
    } else {
      Logger.log(`Optional column "${columnName}" not found — skipping.`);
    }
  }

  return columnMap;
}

/**
 * Gets the interpretation prompt from the Prompts sheet
 */
function getPromptFromSheet(spreadsheet) {
  try {
    const promptsSheet = spreadsheet.getSheetByName(CONFIG.PROMPTS_SHEET_NAME);

    if (!promptsSheet) {
      throw new Error(
        `"${CONFIG.PROMPTS_SHEET_NAME}" sheet not found. Please create it with prompt entries in columns A and B.`,
      );
    }

    const data = promptsSheet.getDataRange().getValues();
    const promptEntry = findPromptConfigEntry(
      data,
      CONFIG.INTERPRET_PROMPT_NAME,
    );

    if (promptEntry) {
      if (!promptEntry.text) {
        throw new Error(`Prompt "${CONFIG.INTERPRET_PROMPT_NAME}" is empty.`);
      }
      return promptEntry.text;
    }

    throw new Error(
      `Prompt "${CONFIG.INTERPRET_PROMPT_NAME}" not found in "${CONFIG.PROMPTS_SHEET_NAME}" sheet.`,
    );
  } catch (error) {
    throw new Error(`Failed to load prompt: ${error.message}`);
  }
}

/**
 * Gets the API key from the Start sheet (cell B3)
 * @param {GoogleAppsScript.Spreadsheet.Spreadsheet} spreadsheet - The spreadsheet
 * @returns {string} API key from cell B3
 */
function getAPIKeyFromSheet(spreadsheet) {
  try {
    const startSheet = spreadsheet.getSheetByName(CONFIG.START_SHEET_NAME);

    if (!startSheet) {
      throw new Error(
        `Sheet "${CONFIG.START_SHEET_NAME}" not found. Please create it with API key in cell ${CONFIG.API_KEY_CELL}.`,
      );
    }

    const apiKey = startSheet.getRange(CONFIG.API_KEY_CELL).getValue();

    if (!apiKey || String(apiKey).trim() === "") {
      throw new Error(
        `API key not found in cell ${CONFIG.API_KEY_CELL} of "${CONFIG.START_SHEET_NAME}" sheet. Please enter your API key.`,
      );
    }

    return String(apiKey).trim();
  } catch (error) {
    throw new Error(`Failed to read API key from sheet: ${error.message}`);
  }
}

/**
 * Gets the AI provider from the Start sheet (cell C3)
 * @param {GoogleAppsScript.Spreadsheet.Spreadsheet} spreadsheet - The spreadsheet
 * @returns {string} Provider name ("OPENAI" or "GEMINI")
 */
function getAIProvider(spreadsheet) {
  try {
    const startSheet = spreadsheet.getSheetByName(CONFIG.START_SHEET_NAME);

    if (!startSheet) {
      Logger.log(
        `"${CONFIG.START_SHEET_NAME}" sheet not found, defaulting to OpenAI`,
      );
      return "OPENAI";
    }

    const providerValue = startSheet
      .getRange(CONFIG.AI_PROVIDER_CELL)
      .getValue();

    const provider = String(providerValue).trim().toUpperCase();

    // Check for various forms of provider names
    if (provider === "OPENAI" || provider === "OPEN AI") {
      Logger.log("Using OpenAI provider");
      return "OPENAI";
    } else if (provider === "GEMINI") {
      Logger.log("Using Gemini provider");
      return "GEMINI";
    } else {
      Logger.log(
        `Unknown provider value "${providerValue}", defaulting to OpenAI`,
      );
      return "OPENAI";
    }
  } catch (error) {
    Logger.log(
      `Error reading AI provider: ${error.message}, defaulting to OpenAI`,
    );
    return "OPENAI";
  }
}

/**
 * Gets the confidence threshold from the Prompts sheet
 */
function getConfidenceThreshold(spreadsheet) {
  try {
    const promptsSheet = spreadsheet.getSheetByName(CONFIG.PROMPTS_SHEET_NAME);

    if (!promptsSheet) {
      return CONFIG.DEFAULT_CONFIDENCE_THRESHOLD;
    }

    const data = promptsSheet.getDataRange().getValues();
    const confidenceEntry = findPromptConfigEntry(
      data,
      CONFIG.CONFIDENCE_LEVEL_NAME,
    );

    if (confidenceEntry) {
      const threshold = parseInt(confidenceEntry.text, 10);
      if (!isNaN(threshold) && threshold >= 0 && threshold <= 100) {
        Logger.log(`Using confidence threshold: ${threshold}`);
        return threshold;
      }
    }

    Logger.log(
      `Confidence threshold not found, using default: ${CONFIG.DEFAULT_CONFIDENCE_THRESHOLD}`,
    );
    return CONFIG.DEFAULT_CONFIDENCE_THRESHOLD;
  } catch (error) {
    Logger.log(`Error reading confidence threshold: ${error.message}`);
    return CONFIG.DEFAULT_CONFIDENCE_THRESHOLD;
  }
}

function normalizePromptConfigNameCell(value) {
  const normalized = String(value || "").replace(/\s+/g, " ").trim();
  const prefixedMatch = normalized.match(/^prompt name\s+(.+)$/i);
  return prefixedMatch ? prefixedMatch[1].trim() : normalized;
}

function normalizePromptConfigTextCell(value) {
  const text = String(value || "").trim();
  return text.replace(/^prompt text\s+/i, "").trim();
}

function findPromptConfigEntry(data, entryName) {
  for (let i = 0; i < data.length; i++) {
    const promptName = normalizePromptConfigNameCell(
      data[i][CONFIG.PROMPT_NAME_COLUMN - 1],
    );

    if (promptName === entryName) {
      return {
        rowNumber: i + 1,
        name: promptName,
        text: normalizePromptConfigTextCell(
          data[i][CONFIG.PROMPT_TEXT_COLUMN - 1],
        ),
      };
    }
  }

  return null;
}

/**
 * Normalizes conformance value to handle AI response variations
 * @param {string} value - Raw value from AI
 * @returns {string} Normalized valid conformance value or original if already valid
 */
function normalizeConformanceValue(value) {
  if (!value) return "";

  const normalized = String(value).trim();

  // Check if already valid (exact match with proper capitalization)
  if (CONFIG.VALID_CONFORMANCE_VALUES.includes(normalized)) {
    return normalized;
  }

  // Normalize common variations (case-insensitive matching)
  const lowerValue = normalized.toLowerCase();

  // Map variations to correct values
  const mappings = {
    // Supports variations
    supports: "Supports",
    support: "Supports",
    yes: "Supports",
    supported: "Supports",

    // Partially Supports variations
    "partially supports": "Partially Supports",
    "partial supports": "Partially Supports",
    "partially support": "Partially Supports",
    "partial support": "Partially Supports",
    partially: "Partially Supports",
    partial: "Partially Supports",
    "supports with exceptions": "Partially Supports",
    "supports with exception": "Partially Supports",
    sometimes: "Partially Supports",

    // Does Not Support variations
    "does not support": "Does Not Support",
    "doesn't support": "Does Not Support",
    "does not supports": "Does Not Support",
    "not supported": "Does Not Support",
    "not support": "Does Not Support",
    no: "Does Not Support",
    fails: "Does Not Support",
    failed: "Does Not Support",

    // Not Applicable variations
    "not applicable": "Not Applicable",
    "n/a": "Not Applicable",
    na: "Not Applicable",
    "not apply": "Not Applicable",

    // Not Evaluated variations
    "not evaluated": "Not Evaluated",
    "not assessed": "Not Evaluated",
    unevaluated: "Not Evaluated",
    unknown: "Not Evaluated",
  };

  if (mappings[lowerValue]) {
    return mappings[lowerValue];
  }

  // If no mapping found, return original value (will be logged as invalid)
  return normalized;
}

/**
 * Finds rows that have conformance data from extraction.
 */
function findRowsWithConformanceData(sheet, columnMap, startRow, endRow) {
  const numRows = endRow - startRow + 1;
  const conformanceCol = columnMap.CONFORMANCE_LEVEL;

  const conformanceData = sheet
    .getRange(startRow, conformanceCol, numRows, 1)
    .getValues();

  const rowsToProcess = [];

  for (let i = 0; i < numRows; i++) {
    const conformance = conformanceData[i][0];
    const hasConformance = conformance && String(conformance).trim() !== "";

    if (hasConformance) {
      rowsToProcess.push(startRow + i);
    }
  }

  Logger.log(
    `Found ${rowsToProcess.length} rows to interpret (from ${startRow} to ${endRow})`,
  );
  if (rowsToProcess.length > 0 && rowsToProcess.length <= 20) {
    Logger.log(`Rows to process: ${rowsToProcess.join(", ")}`);
  }

  return rowsToProcess;
}

/**
 * Processes rows with AI to interpret conformance levels
 */
function processRowsWithAI(
  sheet,
  columnMap,
  rowNumbers,
  systemPrompt,
  confidenceThreshold,
) {
  let successCount = 0;
  let errorCount = 0;

  // Determine batch size; CONFIG.BATCH_SIZE must be a positive integer, otherwise process all at once
  const batchSize =
    CONFIG.BATCH_SIZE > 0 ? CONFIG.BATCH_SIZE : rowNumbers.length;

  const totalBatches = Math.ceil(rowNumbers.length / batchSize);

  // Process in batches
  for (let i = 0; i < rowNumbers.length; i += batchSize) {
    const batchRows = rowNumbers.slice(i, i + batchSize);
    const batchNum = Math.floor(i / batchSize) + 1;
    let batchSucceeded = false;

    // Collect all data for this batch (outside the retry loop — data doesn't change)
    const batchData = [];
    for (const rowNum of batchRows) {
      const conformanceLevel = sheet
        .getRange(rowNum, columnMap.CONFORMANCE_LEVEL)
        .getValue();
      const remarks = sheet.getRange(rowNum, columnMap.REMARKS).getValue();
      const criteria = sheet.getRange(rowNum, columnMap.CRITERIA).getValue();

      batchData.push({
        rowNum: rowNum,
        criteria: String(criteria || "").trim(),
        conformanceLevel: String(conformanceLevel || "").trim(),
        remarks: String(remarks || "").trim(),
      });
    }

    const userMessage = buildBatchMessage(batchData);

    // Attempt the API call with one automatic retry on failure
    for (let attempt = 1; attempt <= 2; attempt++) {
      try {
        showProgress(
          `Processing batch ${batchNum} of ${totalBatches} (${batchData.length} rows)` +
            (attempt > 1 ? ` — retry ${attempt - 1}...` : "..."),
        );

        const batchInterpretations = callAIForInterpretation(
          systemPrompt,
          userMessage,
        );

        // Build a lookup map from entryIndex → interpretation for robust matching.
        // Falls back to positional index if the AI does not return entryIndex fields.
        const interpretationByIndex = {};
        if (Array.isArray(batchInterpretations)) {
          batchInterpretations.forEach((item, pos) => {
            const idx =
              item && typeof item.entryIndex === "number"
                ? item.entryIndex
                : pos;
            interpretationByIndex[idx] = item;
          });
        }

        // Write results for each row in the batch
        for (let j = 0; j < batchData.length; j++) {
          const rowNum = batchData[j].rowNum;

          // Safety guard: never overwrite the header row or any row before it
          if (columnMap._headerRow && rowNum <= columnMap._headerRow) {
            Logger.log(
              `SAFETY: Skipping row ${rowNum} — at or before header row ${columnMap._headerRow}.`,
            );
            errorCount++;
            continue;
          }

          const interpretation = interpretationByIndex[j] || {};

          try {
            writeInterpretedValues(
              sheet,
              columnMap,
              rowNum,
              interpretation,
              confidenceThreshold,
            );
            successCount++;
          } catch (writeError) {
            Logger.log(`Error writing row ${rowNum}: ${writeError.message}`);
            errorCount++;
          }
        }

        batchSucceeded = true;
        break; // Exit retry loop on success
      } catch (apiError) {
        Logger.log(
          `Batch ${batchNum} attempt ${attempt} failed: ${apiError.message}`,
        );
        if (attempt < 2) {
          // Wait 5 seconds before retrying
          Logger.log(`Waiting 5s before retry...`);
          Utilities.sleep(5000);
        }
      }
    }

    if (!batchSucceeded) {
      // Both attempts failed — notify the user and count the errors
      const failedRows = batchRows.join(", ");
      Logger.log(
        `Batch ${batchNum} permanently failed. Affected rows: ${failedRows}`,
      );
      SpreadsheetApp.getActiveSpreadsheet().toast(
        `Batch ${batchNum}/${totalBatches} failed after retry. Rows skipped: ${failedRows}. Check Logs (Extensions > Apps Script > Executions) for details.`,
        "Batch Error",
        15,
      );
      errorCount += batchRows.length;
    }

    // Rate limiting between batches — outside try/catch so a sleep failure
    // never contaminates the error count for the batch just completed.
    if (i + batchSize < rowNumbers.length) {
      Utilities.sleep(CONFIG.API_DELAY_MS);
    }
  }

  return { success: successCount, errors: errorCount };
}

/**
 * Builds a batch message with multiple rows for AI interpretation
 */
function buildBatchMessage(batchData) {
  let message =
    "Analyze the following VPAT entries and return a JSON array with interpretations:\n\n";

  batchData.forEach((item, index) => {
    message += `Entry ${index}:\n`;
    if (item.criteria) {
      message += `Criteria: ${item.criteria}\n`;
    }
    message += `Conformance Level: ${item.conformanceLevel}\n`;
    message += `Remarks: ${item.remarks}\n\n`;
  });

  message += `Return a JSON array — one object per entry, IN THE SAME ORDER — with this structure:
{
  "entryIndex": <integer matching the Entry number above>,
  "conformanceLevel": "Supports|Partially Supports|Does Not Support|Not Applicable|Not Evaluated",
  "appliesToMediums": "Comma-separated list of mediums EXPLICITLY mentioned by the author in the Remarks. Choose ONLY from: Web, Electronic Docs, Software, Closed, Authoring Tool. Use empty string if none are explicitly named.",
  "comment": "Short evaluation summary explaining why the standardized conformance level fits the VPAT remarks",
  "confidence": <integer 0-100>
}

IMPORTANT:
- Include exactly one object per entry, keeping the original order.
- The "entryIndex" must match the Entry number exactly.
- Do NOT add extra keys or commentary outside the JSON array.`;

  return message;
}

/**
 * Writes interpreted values to the sheet
 */
function writeInterpretedValues(
  sheet,
  columnMap,
  rowNum,
  interpretation,
  confidenceThreshold,
) {
  // --- Standardized Conformance Level ---
  const rawConformance = interpretation.conformanceLevel || "";
  Logger.log(
    `Row ${rowNum}, conformanceLevel: Raw AI value = "${rawConformance}"`,
  );
  const normalizedConformance = normalizeConformanceValue(rawConformance);

  if (
    normalizedConformance &&
    !CONFIG.VALID_CONFORMANCE_VALUES.includes(normalizedConformance)
  ) {
    Logger.log(
      `Row ${rowNum}: INVALID conformance "${rawConformance}" (normalized: "${normalizedConformance}"). Defaulting to "Not Evaluated".`,
    );
    sheet
      .getRange(rowNum, columnMap.CONFORMANCE_INTERPRETED)
      .setValue("Not Evaluated");
  } else {
    if (normalizedConformance !== rawConformance) {
      Logger.log(
        `Row ${rowNum}: Normalized "${rawConformance}" -> "${normalizedConformance}"`,
      );
    }
    sheet
      .getRange(rowNum, columnMap.CONFORMANCE_INTERPRETED)
      .setValue(normalizedConformance || "Not Evaluated");
  }

  // --- Applies to (Mediums) ---
  // AI returns a comma-separated string of mediums explicitly mentioned by the author.
  // Valid values: Web, Electronic Docs, Software, Closed, Authoring Tool
  const validMediums = [
    "Web",
    "Electronic Docs",
    "Software",
    "Closed",
    "Authoring Tool",
  ];
  const rawMediums = String(interpretation.appliesToMediums || "").trim();

  // Validate each medium token and keep only recognised ones
  const filteredMediums = rawMediums
    ? rawMediums
        .split(",")
        .map((m) => m.trim())
        .filter((m) =>
          validMediums.some((v) => v.toLowerCase() === m.toLowerCase()),
        )
        // Normalise casing to the canonical form
        .map((m) =>
          validMediums.find((v) => v.toLowerCase() === m.toLowerCase()),
        )
    : [];

  if (columnMap.APPLIES_TO_MEDIUMS) {
    sheet
      .getRange(rowNum, columnMap.APPLIES_TO_MEDIUMS)
      .setValue(filteredMediums.join(", "));
    Logger.log(
      `Row ${rowNum}, appliesToMediums: "${rawMediums}" -> stored: "${filteredMediums.join(", ")}"`,
    );
  }

  // --- Confidence / AI Evaluation Summary ---
  const confidence = parseInt(interpretation.confidence, 10) || 0;

  Logger.log(
    `Row ${rowNum}: Confidence=${confidence}, Threshold=${confidenceThreshold}`,
  );

  const evaluationSummary =
    String(interpretation.comment || "").trim() ||
    (confidence < confidenceThreshold ? "Low confidence - please review" : "");
  sheet.getRange(rowNum, columnMap.AI_COMMENT).setValue(evaluationSummary);
}

/*******************************************************
 * AI API INTEGRATION
 *******************************************************/

/**
 * Dispatches to the correct AI provider for interpretation
 */
function callAIForInterpretation(systemPrompt, userMessage) {
  // Get provider from sheet dynamically
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const provider = getAIProvider(ss);

  if (provider === "OPENAI") {
    return callOpenAIForInterpretation(systemPrompt, userMessage);
  } else if (provider === "GEMINI") {
    return callGeminiForInterpretation(systemPrompt, userMessage);
  } else {
    throw new Error(`Unsupported provider: ${provider}`);
  }
}

/**
 * Calls OpenAI API directly
 */
function callOpenAIForInterpretation(systemPrompt, userMessage) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const apiKey = getAPIKeyFromSheet(ss);

  const url = `${CONFIG.AI_MODEL.OPENAI_BASE_URL}/chat/completions`;

  const payload = {
    model: CONFIG.AI_MODEL.OPENAI_MODEL,
    messages: [
      { role: "system", content: systemPrompt },
      { role: "user", content: userMessage },
    ],
    temperature: 0.2, // Match Gemini's low temperature for consistent/deterministic output
    max_tokens: 8192, // Match Gemini's token limit to avoid truncation on large batches
  };

  const options = {
    method: "post",
    contentType: "application/json",
    headers: {
      Authorization: `Bearer ${apiKey}`,
    },
    payload: JSON.stringify(payload),
    muteHttpExceptions: true,
  };

  Logger.log(`Calling OpenAI API: ${url}`);
  Logger.log(`Model: ${CONFIG.AI_MODEL.OPENAI_MODEL}`);
  Logger.log(`Payload size: ${JSON.stringify(payload).length} bytes`);

  const response = UrlFetchApp.fetch(url, options);
  const statusCode = response.getResponseCode();
  const responseText = response.getContentText();

  Logger.log(`Response Status: ${statusCode}`);

  // Handle 429 rate limit with retry (matching Gemini behaviour)
  if (statusCode === 429) {
    let retryDelayMs = 60000; // Default 60s for OpenAI
    try {
      // OpenAI includes a Retry-After header (seconds)
      const retryAfter =
        response.getHeaders()["Retry-After"] ||
        response.getHeaders()["retry-after"];
      if (retryAfter) {
        const seconds = parseInt(retryAfter, 10);
        if (!isNaN(seconds)) retryDelayMs = (seconds + 2) * 1000; // Add 2s buffer
      }
    } catch (e) {
      /* ignore, use default */
    }

    Logger.log(
      `[OpenAI] 429 rate limit hit. Retrying after ${retryDelayMs / 1000}s...`,
    );
    showProgress(
      `Rate limit hit. Waiting ${Math.round(retryDelayMs / 1000)}s before retry...`,
    );
    Utilities.sleep(retryDelayMs);

    // Retry once
    const retryResponse = UrlFetchApp.fetch(url, options);
    const retryStatus = retryResponse.getResponseCode();
    const retryText = retryResponse.getContentText();
    Logger.log(`[OpenAI] Retry response status: ${retryStatus}`);

    if (retryStatus !== 200) {
      let errorDetails = retryText;
      try {
        errorDetails = JSON.stringify(JSON.parse(retryText), null, 2);
      } catch (e) {
        /* not JSON */
      }
      throw new Error(
        `OpenAI API returned ${retryStatus} after retry. Details: ${errorDetails}`,
      );
    }

    return parseOpenAIResponseText(retryText);
  }

  if (statusCode !== 200) {
    let errorDetails = responseText;
    try {
      const errorData = JSON.parse(responseText);
      errorDetails = JSON.stringify(errorData, null, 2);
    } catch (e) {
      // Response is not JSON
    }
    throw new Error(
      `OpenAI API returned ${statusCode}. Details: ${errorDetails}`,
    );
  }

  return parseOpenAIResponseText(responseText);
}

/**
 * Parses the raw text from an OpenAI API response into a JSON array.
 * Mirrors the robustness of parseGeminiResponseText with the same fallback chain.
 * @param {string} responseText - Raw response body from OpenAI
 * @returns {Array} Parsed array of AI response objects
 */
function parseOpenAIResponseText(responseText) {
  const data = JSON.parse(responseText);

  if (!data.choices || !data.choices[0] || !data.choices[0].message) {
    throw new Error(`Invalid OpenAI response structure: ${responseText}`);
  }

  const content = data.choices[0].message.content;
  Logger.log(`OpenAI Response length: ${content.length} characters`);
  Logger.log(`OpenAI Response (first 500 chars): ${content.substring(0, 500)}`);
  Logger.log(
    `OpenAI Response (last 500 chars): ${content.substring(Math.max(0, content.length - 500))}`,
  );

  // Strip markdown code fences if present
  let cleanContent = content.trim();
  if (cleanContent.startsWith("```")) {
    cleanContent = cleanContent.replace(/^```(?:json)?\s*\n?/, "");
    cleanContent = cleanContent.replace(/\n?```\s*$/, "");
  }

  // Parse JSON response (handle both single object and array)
  try {
    const parsed = JSON.parse(cleanContent);
    const resultArray = Array.isArray(parsed) ? parsed : [parsed];
    Logger.log(
      `Successfully parsed ${resultArray.length} items from OpenAI response`,
    );
    return resultArray;
  } catch (e) {
    Logger.log(`JSON parse error: ${e.message}`);
    Logger.log(`Attempting to extract valid JSON from response...`);

    // Try to extract a JSON array from the response
    const jsonMatch = cleanContent.match(/\[[\s\S]*\]/);
    if (jsonMatch) {
      try {
        const parsed = JSON.parse(jsonMatch[0]);
        const resultArray = Array.isArray(parsed) ? parsed : [parsed];
        Logger.log(`Extracted ${resultArray.length} items from partial JSON`);
        return resultArray;
      } catch (e2) {
        Logger.log(`Failed to parse extracted JSON: ${e2.message}`);

        // Try to fix incomplete JSON array by truncating to last complete object
        let fixedJson = jsonMatch[0].trim();
        Logger.log(
          `Attempting to fix truncated JSON (length: ${fixedJson.length})...`,
        );

        const lastBrace = fixedJson.lastIndexOf("}");
        if (lastBrace !== -1) {
          fixedJson = fixedJson.substring(0, lastBrace + 1) + "]";
          try {
            const parsed = JSON.parse(fixedJson);
            const resultArray = Array.isArray(parsed) ? parsed : [parsed];
            Logger.log(
              `Fixed truncated JSON, extracted ${resultArray.length} items (response was cut off)`,
            );
            return resultArray;
          } catch (e3) {
            Logger.log(`Failed to fix at last brace: ${e3.message}`);

            // Last resort: find the last complete object by scanning backwards
            const lastCompleteMatch = fixedJson.match(
              /([\s\S]*\})\s*[,\]]?\s*[^\]]*$/,
            );
            if (lastCompleteMatch) {
              const attempt = lastCompleteMatch[1].trim();
              const finalAttempt = attempt.startsWith("[")
                ? attempt + "]"
                : "[" + attempt + "]";
              try {
                const parsed = JSON.parse(finalAttempt);
                const resultArray = Array.isArray(parsed) ? parsed : [parsed];
                Logger.log(
                  `Last-resort fix extracted ${resultArray.length} items`,
                );
                return resultArray;
              } catch (e4) {
                Logger.log(`Last-resort fix also failed: ${e4.message}`);
              }
            }
          }
        }
      }
    }

    // Final fallback: try extracting a single object
    const objMatch = cleanContent.match(/\{[\s\S]*\}/);
    if (objMatch) {
      try {
        const parsed = JSON.parse(objMatch[0]);
        Logger.log(`Extracted single object from OpenAI response`);
        return [parsed];
      } catch (e5) {
        Logger.log(`Single object extraction also failed: ${e5.message}`);
      }
    }

    Logger.log(`Full response for debugging: ${cleanContent}`);
    throw new Error(
      `Failed to parse OpenAI response as JSON. Response length: ${content.length} chars. Parse error: ${e.message}`,
    );
  }
}

/**
 * Calls Gemini API for interpretation
 */
function callGeminiForInterpretation(systemPrompt, userMessage) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const apiKey = getAPIKeyFromSheet(ss);

  const url = `${CONFIG.AI_MODEL.GEMINI_BASE_URL}/models/${CONFIG.AI_MODEL.GEMINI_MODEL}:generateContent?key=${apiKey}`;

  // Gemini uses a different format: contents array with parts
  const payload = {
    contents: [
      {
        parts: [
          {
            text: `${systemPrompt}\n\n${userMessage}`,
          },
        ],
      },
    ],
    generationConfig: {
      temperature: 0.2,
      maxOutputTokens: 8192, // Increased to handle larger batches
    },
  };

  const options = {
    method: "post",
    contentType: "application/json",
    payload: JSON.stringify(payload),
    muteHttpExceptions: true,
  };

  Logger.log(`Calling Gemini API: ${CONFIG.AI_MODEL.GEMINI_MODEL}`);
  Logger.log(`Payload size: ${JSON.stringify(payload).length} bytes`);

  const response = UrlFetchApp.fetch(url, options);
  const statusCode = response.getResponseCode();
  const responseText = response.getContentText();

  Logger.log(`Response Status: ${statusCode}`);

  if (statusCode === 429) {
    // Parse retryDelay from Gemini error response and retry once
    let retryDelayMs = 30000; // Default 30s
    try {
      const errorData = JSON.parse(responseText);
      const retryInfo = errorData?.error?.details?.find(
        (d) => d["@type"] === "type.googleapis.com/google.rpc.RetryInfo",
      );
      if (retryInfo?.retryDelay) {
        const seconds = parseInt(retryInfo.retryDelay.replace("s", ""), 10);
        if (!isNaN(seconds)) retryDelayMs = (seconds + 2) * 1000; // Add 2s buffer
      }
    } catch (e) {
      /* ignore parse error, use default */
    }

    Logger.log(
      `[Gemini] 429 rate limit hit. Retrying after ${retryDelayMs / 1000}s...`,
    );
    showProgress(
      `Rate limit hit. Waiting ${Math.round(retryDelayMs / 1000)}s before retry...`,
    );
    Utilities.sleep(retryDelayMs);

    // Retry the request once
    const retryResponse = UrlFetchApp.fetch(url, options);
    const retryStatus = retryResponse.getResponseCode();
    const retryText = retryResponse.getContentText();
    Logger.log(`[Gemini] Retry response status: ${retryStatus}`);

    if (retryStatus !== 200) {
      let errorDetails = retryText;
      try {
        errorDetails = JSON.stringify(JSON.parse(retryText), null, 2);
      } catch (e) {
        /* not JSON */
      }
      throw new Error(
        `Gemini API returned ${retryStatus} after retry. Details: ${errorDetails}`,
      );
    }

    // Reassign for processing below
    Object.defineProperty(options, "_retryData", { value: retryText });
    return parseGeminiResponseText(retryText);
  }

  if (statusCode !== 200) {
    let errorDetails = responseText;
    try {
      const errorData = JSON.parse(responseText);
      errorDetails = JSON.stringify(errorData, null, 2);
    } catch (e) {
      // Response is not JSON
    }
    throw new Error(
      `Gemini API returned ${statusCode}. Details: ${errorDetails}`,
    );
  }

  return parseGeminiResponseText(responseText);
}

/**
 * Parses the raw text from a Gemini API response into a JSON array.
 * Extracted to allow reuse between initial call and 429 retry.
 * @param {string} responseText - Raw response body from Gemini
 * @returns {Array} Parsed array of AI response objects
 */
function parseGeminiResponseText(responseText) {
  const data = JSON.parse(responseText);

  // Gemini response structure: { candidates: [{ content: { parts: [{ text: "..." }] } }] }
  if (
    !data.candidates ||
    !data.candidates[0] ||
    !data.candidates[0].content ||
    !data.candidates[0].content.parts ||
    !data.candidates[0].content.parts[0]
  ) {
    throw new Error(`Invalid Gemini response structure: ${responseText}`);
  }

  const content = data.candidates[0].content.parts[0].text;
  Logger.log(`Gemini Response length: ${content.length} characters`);
  Logger.log(`Gemini Response (first 500 chars): ${content.substring(0, 500)}`);
  Logger.log(
    `Gemini Response (last 500 chars): ${content.substring(Math.max(0, content.length - 500))}`,
  );

  // Strip markdown code fences if present
  let cleanContent = content.trim();
  if (cleanContent.startsWith("```")) {
    cleanContent = cleanContent.replace(/^```(?:json)?\s*\n?/, "");
    cleanContent = cleanContent.replace(/\n?```\s*$/, "");
  }

  // Parse JSON response (handle both single object and array)
  try {
    const parsed = JSON.parse(cleanContent);
    const resultArray = Array.isArray(parsed) ? parsed : [parsed];
    Logger.log(
      `Successfully parsed ${resultArray.length} items from Gemini response`,
    );
    return resultArray;
  } catch (e) {
    Logger.log(`JSON parse error: ${e.message}`);
    Logger.log(`Attempting to extract valid JSON from response...`);

    // If not valid JSON, try to extract JSON array from the response
    const jsonMatch = cleanContent.match(/\[[\s\S]*\]/);
    if (jsonMatch) {
      try {
        const parsed = JSON.parse(jsonMatch[0]);
        const resultArray = Array.isArray(parsed) ? parsed : [parsed];
        Logger.log(`Extracted ${resultArray.length} items from partial JSON`);
        return resultArray;
      } catch (e2) {
        Logger.log(`Failed to parse extracted JSON: ${e2.message}`);

        // Try to fix incomplete JSON array by truncating to last complete object
        let fixedJson = jsonMatch[0].trim();
        Logger.log(
          `Attempting to fix truncated JSON (length: ${fixedJson.length})...`,
        );

        // Find the last complete JSON object closing brace
        const lastBrace = fixedJson.lastIndexOf("}");
        if (lastBrace !== -1) {
          fixedJson = fixedJson.substring(0, lastBrace + 1) + "]";
          try {
            const parsed = JSON.parse(fixedJson);
            const resultArray = Array.isArray(parsed) ? parsed : [parsed];
            Logger.log(
              `Fixed truncated JSON, extracted ${resultArray.length} items (response was cut off)`,
            );
            return resultArray;
          } catch (e3) {
            Logger.log(`Failed to fix at last brace: ${e3.message}`);

            // Last resort: find the last complete object by scanning backwards for "},\n" or "}\n"
            const lastCompleteMatch = fixedJson.match(
              /([\s\S]*\})\s*[,\]]?\s*[^\]]*$/,
            );
            if (lastCompleteMatch) {
              const attempt = lastCompleteMatch[1].trim();
              const finalAttempt = attempt.startsWith("[")
                ? attempt + "]"
                : "[" + attempt + "]";
              try {
                const parsed = JSON.parse(finalAttempt);
                const resultArray = Array.isArray(parsed) ? parsed : [parsed];
                Logger.log(
                  `Last-resort fix extracted ${resultArray.length} items`,
                );
                return resultArray;
              } catch (e4) {
                Logger.log(`Last-resort fix also failed: ${e4.message}`);
              }
            }
          }
        }
      }
    }

    // Final fallback: try extracting a single object (mirrors parseOpenAIResponseText)
    const objMatch = cleanContent.match(/\{[\s\S]*\}/);
    if (objMatch) {
      try {
        const parsed = JSON.parse(objMatch[0]);
        Logger.log(`Extracted single object from Gemini response`);
        return [parsed];
      } catch (e5) {
        Logger.log(`Single object extraction also failed: ${e5.message}`);
      }
    }

    Logger.log(`Full response for debugging: ${cleanContent}`);
    throw new Error(
      `Failed to parse Gemini response as JSON. Response length: ${content.length} chars. Parse error: ${e.message}`,
    );
  }
}

