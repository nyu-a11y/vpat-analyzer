/**
 * Main function to analyze VPAT quality checklist
 * Reads questions from "Quality Requirements" sheet
 * Groups by criteria number and processes in batches
 * Writes AI responses back to the quality analysis output columns
 */
function analyzeQualityChecklist() {
  const ui = SpreadsheetApp.getUi();
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  try {
    // Step 1: Get file ID from Start sheet
    const fileId = getVPATFileIdForAnalysis();
    if (!fileId) {
      return { success: false, reason: "no-file-id" };
    }

    // Step 2: Load questions from Quality Requirements sheet
    showProgress("Loading quality requirements...");
    const requirements = loadQualityRequirements(ss);

    if (requirements.length === 0) {
      throw new Error(
        `No requirements found in "${CONFIG.QUALITY_CHECKLIST.SHEET_NAME}" sheet`,
      );
    }

    // Step 3: Group requirements by Category column value
    const criteriaGroups = groupRequirementsByCriteria(requirements);
    Logger.log(
      `Grouped ${requirements.length} requirements into ${criteriaGroups.length} category groups`,
    );

    // Step 4: Load VPAT document text
    showProgress("Loading VPAT document...");
    const documentText = extractFullDocumentText(fileId);
    Logger.log(`Extracted ${documentText.length} characters from document`);

    // Step 5: Get system prompt
    const systemPrompt = getQualityChecklistPrompt(ss);

    // Step 6: Process category groups in batches
    showProgress(`Analyzing ${criteriaGroups.length} category groups...`);
    const allResponses = processCriteriaGroups(
      criteriaGroups,
      documentText,
      systemPrompt,
    );

    // Step 7: Write responses back to the quality analysis output columns
    showProgress("Writing AI responses to sheet...");
    const writeResults = writeQualityResponses(ss, allResponses);

    if (writeResults.rowsWritten === 0) {
      SpreadsheetApp.getActiveSpreadsheet().toast(
        "Quality analysis ran, but no rows were written to the sheet.",
        "Nothing Processed",
        10,
      );
      return { success: false, reason: "no-writes", results: writeResults };
    }

    SpreadsheetApp.getActiveSpreadsheet().toast(
      `✓ Quality analysis complete! Updated ${writeResults.rowsWritten} of ${writeResults.totalRows} requirements`,
      "Success",
      10,
    );
    return { success: true, count: writeResults.rowsWritten, results: writeResults };
  } catch (error) {
    console.error(
      `[analyzeQualityChecklist] Unhandled error during quality checklist analysis. ` +
        `Error: ${error.message}\nStack: ${error.stack}`,
    );
    SpreadsheetApp.getActiveSpreadsheet().toast(
      "Quality analysis failed. Check the Apps Script logs for details.",
      "Quality Analysis Failed",
      10,
    );
    return { success: false, reason: "error", message: error.message };
  } finally {
    hideProgress();
  }
}

/**
 * Gets VPAT file ID from the Start sheet input cell
 * @returns {string|null} File ID or null if not found
 */
function getVPATFileIdForAnalysis() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const startSheet = ss.getSheetByName(CONFIG.START_SHEET_NAME);

  if (!startSheet) {
    throw new Error(
      `Sheet "${CONFIG.START_SHEET_NAME}" not found. Please create it and put the file ID, Google Drive link, or file chip in cell ${CONFIG.FILE_ID_CELL}.`,
    );
  }

  confirmStartFileIdCellSelection(startSheet);

  const fileIdRange = startSheet.getRange(CONFIG.FILE_ID_CELL);
  const fileId = resolveDriveFileIdFromRange(fileIdRange);

  if (!fileId) {
    throw new Error(
      `We couldn't find a usable Google Drive file in cell ${CONFIG.FILE_ID_CELL} of "${CONFIG.START_SHEET_NAME}". Enter the file ID, paste the full Google Drive link, or insert a file chip. If you used a file chip, try adding it again or paste the link instead.`,
    );
  }

  return fileId;
}

/**
 * Reads all column headers from row 1 of the quality checklist sheet and returns
 * a map of CONFIG key → 0-based column index. Throws if a required column is missing.
 * Scans every row until a header row is found (handles title rows above the header).
 * Also sets colMap._headerRow (1-based sheet row of the header).
 * @param {GoogleAppsScript.Spreadsheet.Sheet} sheet
 * @returns {Object} e.g. { REQ_ID: 0, CATEGORY: 2, _headerRow: 2, ... }
 */
function resolveQualityChecklistColumns(sheet) {
  const colHeaders = CONFIG.QUALITY_CHECKLIST.COLUMN_HEADERS;
  const lastRow = sheet.getLastRow();
  const lastCol = sheet.getLastColumn();
  const allRows = sheet.getRange(1, 1, lastRow, lastCol).getValues();

  // Required columns that must be present for the row to count as the header.
  // REQ_ID is intentionally omitted — we auto-generate it when missing.
  const required = [
    "REQUIREMENT_TITLE",
    "REQUIREMENT_DESCRIPTION",
    "AI_RESPONSE",
    "ORIGINAL_FROM_VPAT",
    "AI_EXPLANATION",
  ];

  let colMap = null;
  let headerRowIndex = -1; // 0-based index into allRows

  for (let r = 0; r < allRows.length; r++) {
    const candidate = {};
    allRows[r].forEach((h, idx) => {
      for (const [key, name] of Object.entries(colHeaders)) {
        if (qualityHeaderMatches(h, name)) {
          candidate[key] = idx; // 0-based column index
        }
      }
    });

    // Accept this row as the header if all required columns are present
    const allPresent = required.every((key) => candidate[key] !== undefined);
    if (allPresent) {
      colMap = candidate;
      headerRowIndex = r;
      break;
    }
  }

  if (!colMap) {
    const missing = required
      .filter((key) => !colMap || colMap[key] === undefined)
      .map((key) => colHeaders[key]);
    throw new Error(
      `Could not find a header row containing all required columns in sheet "${sheet.getName()}". ` +
        `Missing: ${missing.join(", ")}. ` +
        `Check spelling — expected: ${required.map((k) => colHeaders[k]).join(", ")}.`,
    );
  }

  colMap._headerRow = headerRowIndex + 1; // store as 1-based sheet row number

  Logger.log(
    `Quality checklist header found at sheet row ${colMap._headerRow}. ` +
      `Column map: ${JSON.stringify(
        Object.fromEntries(
          Object.entries(colMap)
            .filter(([k]) => k !== "_headerRow")
            .map(([k, v]) => [k, v + 1]),
        ),
      )} (1-based)`,
  );
  return colMap;
}

function normalizeQualityHeaderValue(value) {
  return String(value || "").replace(/\s+/g, " ").trim().toLowerCase();
}

function qualityHeaderMatches(headerValue, expectedHeader) {
  const normalizedHeader = normalizeQualityHeaderValue(headerValue);
  const normalizedExpected = normalizeQualityHeaderValue(expectedHeader);

  return (
    normalizedHeader === normalizedExpected ||
    normalizedHeader.endsWith(` ${normalizedExpected}`)
  );
}

/**
 * Loads quality requirements from the single flat table in the Quality Requirements sheet.
 * Columns are resolved by header name — position in the sheet does not matter.
 * The "Category" column is captured and used later to group requirements into batches.
 */
function loadQualityRequirements(spreadsheet) {
  const sheetName = CONFIG.QUALITY_CHECKLIST.SHEET_NAME;
  const sheet = spreadsheet.getSheetByName(sheetName);

  if (!sheet) {
    throw new Error(`Sheet "${sheetName}" not found.`);
  }

  const lastRow = sheet.getLastRow();
  const lastCol = sheet.getLastColumn();

  if (lastRow < 2) {
    throw new Error(`Sheet "${sheetName}" has no data rows.`);
  }

  // Build column map from header row (header may not be on row 1)
  const colMap = resolveQualityChecklistColumns(sheet);
  const headerRowIdx = colMap._headerRow - 1; // 0-based index of header in allData

  const allData = sheet.getRange(1, 1, lastRow, lastCol).getValues();

  const requirements = [];

  // Data starts immediately after the header row
  for (let i = headerRowIdx + 1; i < allData.length; i++) {
    const row = allData[i];
    const reqIdStr =
      colMap.REQ_ID !== undefined
        ? String(row[colMap.REQ_ID] ?? "").trim()
        : "";
    const titleStr = String(
      colMap.REQUIREMENT_TITLE !== undefined
        ? row[colMap.REQUIREMENT_TITLE]
        : "",
    ).trim();
    const descStr = String(
      colMap.REQUIREMENT_DESCRIPTION !== undefined
        ? row[colMap.REQUIREMENT_DESCRIPTION]
        : "",
    ).trim();

    // Skip header-like rows
    if (reqIdStr.match(/^(reqid|req id|requirement id)$/i)) {
      Logger.log(`Row ${i + 1}: skipping repeated header row`);
      continue;
    }

    // Skip fully empty rows
    if (!titleStr && !descStr) {
      continue;
    }

    const category =
      colMap.CATEGORY !== undefined
        ? String(row[colMap.CATEGORY] ?? "").trim() || "Uncategorized"
        : "Uncategorized";

    const sheetRowIndex = i + 1; // 1-based sheet row number (for writing back)

    requirements.push({
      rowIndex: sheetRowIndex,
      category: category,
      reqId: reqIdStr || `REQ_${requirements.length + 1}`,
      title: titleStr,
      description: descStr,
      evaluationGuidance: String(
        colMap.EVALUATION_GUIDANCE !== undefined
          ? row[colMap.EVALUATION_GUIDANCE]
          : "",
      ).trim(),
      impact: String(
        colMap.IMPACT !== undefined ? row[colMap.IMPACT] : "",
      ).trim(),
      type: String(colMap.TYPE !== undefined ? row[colMap.TYPE] : "").trim(),
    });

    Logger.log(
      `Row ${sheetRowIndex}: added "${reqIdStr}" — category="${category}", title="${titleStr.substring(0, 40)}"`,
    );
  }

  Logger.log(
    `Loaded ${requirements.length} quality requirements from "${sheetName}"`,
  );
  return requirements;
}

// loadQualityRequirementsFromRange has been removed — the sheet now uses a single
// flat table with a "Category" column for grouping. See loadQualityRequirements().

/**
 * @deprecated kept as a tombstone marker — do not call
 */
function loadQualityRequirementsFromRange() {
  throw new Error(
    "loadQualityRequirementsFromRange is no longer used. " +
      "Use loadQualityRequirements() instead.",
  );
