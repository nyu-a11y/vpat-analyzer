/**
 * Gets processing configuration from the Start sheet
 * @returns {Object|null} Configuration object with fileId from the Start input cell
 */
function getUserInput() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const startSheet = ss.getSheetByName(CONFIG.START_SHEET_NAME);

  if (!startSheet) {
    throw new Error(
      `Sheet "${CONFIG.START_SHEET_NAME}" not found. Please create it and put the file ID, Google Drive link, or file chip in cell ${CONFIG.FILE_ID_CELL}.`,
    );
  }

  confirmStartFileIdCellSelection(startSheet);

  const fileIdRange = startSheet.getRange(CONFIG.FILE_ID_CELL);
  const fileId = resolveDriveFileIdFromRange(fileIdRange);

  // Validate file ID
  if (!fileId) {
    throw new Error(
      `We couldn't find a usable Google Drive file in cell ${CONFIG.FILE_ID_CELL} of "${CONFIG.START_SHEET_NAME}". Enter the file ID, paste the full Google Drive link, or insert a file chip. If you used a file chip, try adding it again or paste the link instead.`,
    );
  }

  // Return file ID with null for row numbers (process all rows)
  return { fileId: fileId, startRow: null, endRow: null };
}

/**
 * Warns the user when the Drive file cell is still selected.
 * Apps Script can't tell the difference between a selected cell and a cell
 * still being edited, so this confirmation helps prevent using a stale value.
 * @param {GoogleAppsScript.Spreadsheet.Sheet} startSheet - The Start sheet
 */
function confirmStartFileIdCellSelection(startSheet) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const activeSheet = ss.getActiveSheet();
  const activeRange = ss.getActiveRange();

  if (!activeSheet || !activeRange) {
    return;
  }

  if (
    activeSheet.getSheetId() === startSheet.getSheetId() &&
    activeRange.getA1Notation() === CONFIG.FILE_ID_CELL
  ) {
    const ui = SpreadsheetApp.getUi();
    const response = ui.alert(
      "Google Drive File",
      `Cell ${CONFIG.FILE_ID_CELL} is still selected. If you just changed it, press Cancel, then press Enter or click another cell to save it. Press OK to continue with the value already saved in the sheet.`,
      ui.ButtonSet.OK_CANCEL,
    );

    if (response !== ui.Button.OK) {
      throw new Error(
        `Finish entering the Google Drive file in cell ${CONFIG.FILE_ID_CELL} first, then run again.`,
      );
    }
  }
}

/**
 * Resolves a Google Drive file ID from a Start-sheet cell.
 * Supports raw IDs, full Drive URLs, and file chips with link URLs.
 * @param {GoogleAppsScript.Spreadsheet.Range} range - Cell containing the file reference
 * @returns {string} Resolved Drive file ID or empty string if none could be parsed
 */
function resolveDriveFileIdFromRange(range) {
  const richText = range.getRichTextValue();
  const candidates = [];
  let rawIdFallback = "";

  if (richText) {
    const linkUrl = richText.getLinkUrl();
    if (linkUrl) {
      candidates.push(linkUrl);
    }

    const runs = richText.getRuns();
    if (runs && runs.length > 0) {
      for (const run of runs) {
        const runLink = run.getLinkUrl();
        if (runLink) {
          candidates.push(runLink);
          break;
        }
      }
    }
  }

  candidates.push(range.getValue());
  candidates.push(range.getDisplayValue());

  for (const candidate of candidates) {
    const fileId = extractDriveFileId(candidate);
    if (!fileId) {
      continue;
    }

    const candidateText = String(candidate || "").trim();
    if (candidateText === fileId && looksLikeDriveFileId(candidateText)) {
      rawIdFallback = fileId;
      continue;
    }

    if (fileId) {
      return fileId;
    }
  }

  const chipUrl = getDriveFileChipUrlFromRange(range);
  if (chipUrl) {
    return extractDriveFileId(chipUrl);
  }

  if (rawIdFallback && isAccessibleDriveFileId(rawIdFallback)) {
    return rawIdFallback;
  }

  return "";
}

/**
 * Extracts a Google Drive file ID from a raw ID or supported Google URL.
 * @param {string} value - Raw cell value, display text, or link URL
 * @returns {string} Drive file ID or empty string if none could be parsed
 */
function extractDriveFileId(value) {
  const text = String(value || "").trim();

  if (!text) {
    return "";
  }

  if (looksLikeDriveFileId(text)) {
    return text;
  }

  const urlMatch = text.match(/^https?:\/\/([^/?#]+)(\/[^?#]*)?(\?[^#]*)?/i);
  if (!urlMatch) {
    return "";
  }

  const host = urlMatch[1] || "";
  if (!isSupportedGoogleFileUrl(host)) {
    return "";
  }

  const path = urlMatch[2] || "";
  const pathMatch = path.match(/\/d\/([a-zA-Z0-9_-]{20,})/);
  if (pathMatch && pathMatch[1]) {
    return pathMatch[1];
  }

  const query = urlMatch[3] || "";
  const queryMatch = query.match(/[?&]id=([a-zA-Z0-9_-]{20,})/);
  if (queryMatch && queryMatch[1]) {
    return queryMatch[1];
  }

  return "";
}

/**
 * Checks whether a string looks like a Google Drive file ID.
 * @param {string} value - Candidate string
 * @returns {boolean} True when the value matches the expected ID shape
 */
function looksLikeDriveFileId(value) {
  return /^[a-zA-Z0-9_-]{20,}$/.test(String(value || "").trim());
}

/**
 * Checks whether a host belongs to a supported Google Drive/Docs URL.
 * @param {string} hostValue - URL host candidate
 * @returns {boolean} True when the host is a supported Google file URL host
 */
function isSupportedGoogleFileUrl(hostValue) {
  const host = String(hostValue || "").trim().toLowerCase();

  return host === "drive.google.com" || host === "docs.google.com";
}

/**
 * Reads chip metadata for a single cell and returns the first Drive-backed chip URL.
 * Smart chips are exposed through chipRuns in the Sheets API rather than RichTextValue.
 * @param {GoogleAppsScript.Spreadsheet.Range} range - Cell containing the smart chip
 * @returns {string} Chip URL or empty string if no Drive chip could be read
 */
function getDriveFileChipUrlFromRange(range) {
  try {
    const sheet = range.getSheet();
    const spreadsheetId = sheet.getParent().getId();
    const sheetName = sheet.getName().replace(/'/g, "''");
    const rangeA1 = `'${sheetName}'!${range.getA1Notation()}`;
    const fields =
      "sheets.data.rowData.values(chipRuns),sheets.data.rowData.values.formattedValue";
    const url =
      `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}` +
      `?ranges=${encodeURIComponent(rangeA1)}` +
      `&fields=${encodeURIComponent(fields)}`;
    const response = UrlFetchApp.fetch(url, {
      headers: {
        Authorization: `Bearer ${ScriptApp.getOAuthToken()}`,
      },
      muteHttpExceptions: true,
    });

    if (response.getResponseCode() !== 200) {
      Logger.log(
        `Failed to read chip metadata for ${rangeA1}: ${response.getResponseCode()} ${response.getContentText().substring(0, 500)}`,
      );
      return "";
    }

    const data = JSON.parse(response.getContentText());
    const cell = data?.sheets?.[0]?.data?.[0]?.rowData?.[0]?.values?.[0];
    const chipRuns = cell?.chipRuns || [];

    for (const run of chipRuns) {
      const chipUrl = run?.chip?.richLinkProperties?.uri;
      if (chipUrl) {
        return chipUrl;
      }
    }
  } catch (error) {
    Logger.log(`Unable to read chip metadata: ${error.message}`);
  }

  return "";
}

/**
 * Checks whether the script can resolve a Drive file ID to an accessible file.
 * @param {string} fileId - Candidate Drive file ID
 * @returns {boolean} True when the file exists and the script can access it
 */
function isAccessibleDriveFileId(fileId) {
  try {
    DriveApp.getFileById(fileId);
    return true;
  } catch (error) {
    Logger.log(`Drive file lookup failed for candidate ID "${fileId}": ${error.message}`);
    return false;
  }
}

