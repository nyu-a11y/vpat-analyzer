/**
 * Main entry point for filling the Assessment Information sheet.
 * Reads label/value pairs from the VPAT and writes matching rows in sheet 2.
 * Skips Status and Note rows by design.
 * @param {string} fileIdOverride - Optional Drive file ID to reuse from a caller
 * @returns {Object} Processing result
 */
function processAssessmentInformation(fileIdOverride) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(CONFIG.ASSESSMENT_SHEET_NAME);
  let tempDocId = null;

  if (!sheet) {
    throw new Error(
      `Assessment sheet "${CONFIG.ASSESSMENT_SHEET_NAME}" not found. Please create it before running this step.`,
    );
  }

  try {
    const fileId = fileIdOverride || getUserInput().fileId;

    showProgress("Loading VPAT document for assessment information...");
    const documentData = openDocumentForProcessing(fileId);
    tempDocId = documentData.tempDocId;

    const body = documentData.doc.getBody();
    const metadata = extractAssessmentFields(
      body.getText(),
      body.getTables(),
    );

    if (metadata.size === 0) {
      SpreadsheetApp.getActiveSpreadsheet().toast(
        "No assessment information fields were found in the VPAT document.",
        "Nothing Processed",
        10,
      );
      return { success: false, reason: "no-metadata" };
    }

    showProgress("Writing assessment information to sheet...");
    const results = writeAssessmentInformationToSheet(sheet, metadata);

    if (results.rowsUpdated === 0) {
      SpreadsheetApp.getActiveSpreadsheet().toast(
        "No assessment information rows were updated. Check the sheet labels and document metadata.",
        "Nothing Processed",
        10,
      );
      return { success: false, reason: "no-updates", results: results };
    }

    SpreadsheetApp.getActiveSpreadsheet().toast(
      `✓ Assessment information updated ${results.rowsUpdated} of ${results.totalRows} rows`,
      "Success",
      10,
    );
    return { success: true, results: results };
  } catch (error) {
    Logger.log(`Error in processAssessmentInformation: ${error.message}`);
    Logger.log(error.stack);
    SpreadsheetApp.getActiveSpreadsheet().toast(
      `Error: ${error.message}`,
      "Assessment Information Failed",
      10,
    );
    return { success: false, reason: "error", message: error.message };
  } finally {
    cleanup(tempDocId);
    try {
      hideProgress();
    } catch (e) {
      // Ignore progress cleanup errors
    }
  }
}

/**
 * Extracts assessment-information label/value pairs from the document text and tables.
 * @param {string} documentText - Full document text
 * @param {GoogleAppsScript.Document.Table[]} tables - Tables from the document body
 * @returns {Map<string, {label: string, value: string}>} Normalized label -> entry
 */
function extractAssessmentFields(documentText, tables) {
  const metadata = new Map();

  collectAssessmentFieldsFromTables(metadata, tables || []);
  collectAssessmentFieldsFromText(metadata, documentText || "");

  Logger.log(
    `Extracted ${metadata.size} assessment-information fields from the document.`,
  );
  return metadata;
}

/**
 * Collects assessment fields from label/value tables.
 * Handles both 2-column rows and even-numbered label/value pairs across a row.
 * @param {Map<string, {label: string, value: string}>} metadata - Output map
 * @param {GoogleAppsScript.Document.Table[]} tables - Document tables
 */
function collectAssessmentFieldsFromTables(metadata, tables) {
  for (const table of tables) {
    const numRows = table.getNumRows();

    for (let i = 0; i < numRows; i++) {
      const row = table.getRow(i);
      const cellTexts = [];

      for (let c = 0; c < row.getNumCells(); c++) {
        const cellText = getCellText(row.getCell(c));
        if (cellText) {
          cellTexts.push(cellText);
        }
      }

      if (cellTexts.length < 2) {
        continue;
      }

      if (cellTexts.length >= 4 && cellTexts.length % 2 === 0) {
        for (let c = 0; c < cellTexts.length; c += 2) {
          upsertAssessmentField(metadata, cellTexts[c], cellTexts[c + 1]);
        }
        continue;
      }

      upsertAssessmentField(
        metadata,
        cellTexts[0],
        cellTexts.slice(1).join(" "),
      );
    }
  }
}

/**
 * Collects assessment fields from colon-delimited lines in the document text.
 * Supports both inline values and values that continue on following lines.
 * @param {Map<string, {label: string, value: string}>} metadata - Output map
 * @param {string} documentText - Full document text
 */
function collectAssessmentFieldsFromText(metadata, documentText) {
  const lines = String(documentText || "").split(/\r?\n/);

  for (let i = 0; i < lines.length; i++) {
    const line = String(lines[i] || "").trim();
    if (!line) {
      continue;
    }

    const labelOnlyMatch = line.match(/^([^:]{2,80}):\s*$/);
    if (labelOnlyMatch) {
      const valueLines = [];
      let j = i + 1;

      for (; j < lines.length; j++) {
        const nextLine = String(lines[j] || "").trim();
        if (!nextLine) {
          if (valueLines.length > 0) {
            break;
          }
          continue;
        }
        if (/^[^:]{2,80}:\s*(?:\S.*)?$/.test(nextLine)) {
          break;
        }
        valueLines.push(nextLine);
        if (valueLines.length >= 3 || valueLines.join(" ").length >= 300) {
          break;
        }
      }

      if (valueLines.length > 0) {
        upsertAssessmentField(
          metadata,
          labelOnlyMatch[1],
          valueLines.join(" "),
        );
        i = j - 1;
      }
      continue;
    }

    const inlineMatch = line.match(/^([^:]{2,80}):\s*(.+)$/);
    if (inlineMatch) {
      upsertAssessmentField(metadata, inlineMatch[1], inlineMatch[2]);
    }
  }
}

/**
 * Inserts or updates a single assessment-information entry.
 * Prefers more descriptive values when the same label is found multiple times.
 * @param {Map<string, {label: string, value: string}>} metadata - Output map
 * @param {string} label - Raw field label
 * @param {string} value - Raw field value
 */
function upsertAssessmentField(metadata, label, value) {
  if (!isLikelyAssessmentFieldLabel(label)) {
    return;
  }

  const normalizedLabel = normalizeAssessmentFieldLabel(label);
  const cleanedValue = cleanAssessmentFieldValue(value);

  if (!normalizedLabel || !cleanedValue) {
    return;
  }

  const existing = metadata.get(normalizedLabel);
  if (
    !existing ||
    shouldReplaceAssessmentFieldValue(existing.value, cleanedValue)
  ) {
    metadata.set(normalizedLabel, {
      label: String(label || "").replace(/\s+/g, " ").trim(),
      value: cleanedValue,
    });
  }
}

/**
 * Determines whether a label is short and structured enough to be used as a field name.
 * @param {string} label - Candidate label
 * @returns {boolean} True when the label looks like a field name
 */
function isLikelyAssessmentFieldLabel(label) {
  const cleaned = String(label || "").replace(/\s+/g, " ").trim();
  if (!cleaned) {
    return false;
  }
  if (cleaned.length > 80) {
    return false;
  }
  if (cleaned.split(" ").length > 12) {
    return false;
  }
  return /[A-Za-z]/.test(cleaned);
}

/**
 * Normalizes a field label for matching.
 * @param {string} label - Candidate label
 * @returns {string} Normalized label
 */
function normalizeAssessmentFieldLabel(label) {
  return String(label || "")
    .replace(/:\s*$/, "")
    .replace(/&/g, " and ")
    .replace(/\//g, " ")
    .replace(/[()]/g, " ")
    .replace(/[^a-zA-Z0-9\s]/g, " ")
    .replace(/\s+/g, " ")
    .trim()
    .toLowerCase();
}

/**
 * Simplifies a normalized label into a stable token string for fuzzy matching.
 * @param {string} label - Label or normalized label
 * @returns {string} Simplified token string
 */
function simplifyAssessmentFieldLabel(label) {
  const replacements = {
    info: "information",
    desc: "description",
    eval: "evaluation",
    mthd: "method",
    mthds: "methods",
  };
  const stopWords = new Set(["a", "an", "and", "for", "of", "the", "to"]);

  return Array.from(
    new Set(
      normalizeAssessmentFieldLabel(label)
        .split(" ")
        .map((token) => replacements[token] || token)
        .filter((token) => token && !stopWords.has(token)),
    ),
  )
    .sort()
    .join(" ");
}

/**
 * Normalizes stored field values.
 * @param {string} value - Raw field value
 * @returns {string} Cleaned field value
 */
function cleanAssessmentFieldValue(value) {
  return String(value || "").replace(/\s+/g, " ").trim();
}

/**
 * Picks the more useful value when the same field is seen multiple times.
 * @param {string} existingValue - Current value
 * @param {string} nextValue - Newly found value
 * @returns {boolean} True when the new value should replace the existing one
 */
function shouldReplaceAssessmentFieldValue(existingValue, nextValue) {
  const current = cleanAssessmentFieldValue(existingValue);
  const candidate = cleanAssessmentFieldValue(nextValue);

  if (!current) {
    return Boolean(candidate);
  }
  if (!candidate) {
    return false;
  }
  if (candidate.length > current.length + 5) {
    return true;
  }

  return current.endsWith(":") && !candidate.endsWith(":");
}

/**
 * Finds the best matching assessment entry for a sheet row label.
 * @param {string} sheetLabel - Label from the Assessment Information sheet
 * @param {Map<string, {label: string, value: string}>} metadata - Extracted entries
 * @returns {{label: string, value: string}|null} Best matching entry or null
 */
function findAssessmentEntryForLabel(sheetLabel, metadata) {
  const normalizedLabel = normalizeAssessmentFieldLabel(sheetLabel);
  if (!normalizedLabel) {
    return null;
  }

  if (metadata.has(normalizedLabel)) {
    return metadata.get(normalizedLabel);
  }

  let bestEntry = null;
  let bestScore = 0;
  let secondBestScore = 0;

  for (const [candidateLabel, entry] of metadata.entries()) {
    const score = scoreAssessmentFieldMatch(
      normalizedLabel,
      candidateLabel,
    );

    if (score > bestScore) {
      secondBestScore = bestScore;
      bestScore = score;
      bestEntry = entry;
    } else if (score > secondBestScore) {
      secondBestScore = score;
    }
  }

  if (
    bestScore >= CONFIG.ASSESSMENT_INFO.MIN_FUZZY_MATCH_SCORE &&
    bestScore - secondBestScore >= 0.1
  ) {
    return bestEntry;
  }

  return null;
}

/**
 * Scores how well two assessment field labels match.
 * @param {string} label - First label
 * @param {string} candidate - Candidate label
 * @returns {number} Match score from 0 to 1
 */
function scoreAssessmentFieldMatch(label, candidate) {
  const normalizedLabel = normalizeAssessmentFieldLabel(label);
  const normalizedCandidate = normalizeAssessmentFieldLabel(candidate);

  if (!normalizedLabel || !normalizedCandidate) {
    return 0;
  }
  if (normalizedLabel === normalizedCandidate) {
    return 1;
  }

  const simplifiedLabel = simplifyAssessmentFieldLabel(normalizedLabel);
  const simplifiedCandidate = simplifyAssessmentFieldLabel(normalizedCandidate);

  if (simplifiedLabel && simplifiedLabel === simplifiedCandidate) {
    return 0.95;
  }

  const labelTokens = simplifiedLabel ? simplifiedLabel.split(" ") : [];
  const candidateTokens = simplifiedCandidate
    ? simplifiedCandidate.split(" ")
    : [];
  const sharedTokenCount = Array.from(
    new Set(labelTokens.filter((token) => candidateTokens.includes(token))),
  ).length;
  const minTokenCount = Math.min(labelTokens.length, candidateTokens.length);
  const maxTokenCount = Math.max(labelTokens.length, candidateTokens.length);

  if (
    minTokenCount >= 2 &&
    (simplifiedLabel.includes(simplifiedCandidate) ||
      simplifiedCandidate.includes(simplifiedLabel))
  ) {
    return 0.85;
  }

  if (sharedTokenCount >= 2 && maxTokenCount > 0) {
    const ratio = sharedTokenCount / maxTokenCount;
    if (ratio >= 0.75) {
      return 0.8;
    }
  }

  return 0;
}

/**
 * Checks whether a row label should remain untouched by the assessment step.
 * @param {string} label - Sheet row label
 * @returns {boolean} True when the row must be skipped
 */
function shouldSkipAssessmentField(label) {
  const normalizedLabel = normalizeAssessmentFieldLabel(label);
  return CONFIG.ASSESSMENT_INFO.EXCLUDED_FIELD_NAMES.some(
    (excludedLabel) =>
      normalizeAssessmentFieldLabel(excludedLabel) === normalizedLabel,
  );
}

/**
 * Writes extracted assessment information back to the Assessment Information sheet.
 * Assumes each field label lives in the first populated cell of a row and writes
 * to the cell immediately to its right.
 * @param {GoogleAppsScript.Spreadsheet.Sheet} sheet - Assessment sheet
 * @param {Map<string, {label: string, value: string}>} metadata - Extracted entries
 * @returns {{totalRows: number, rowsUpdated: number, rowsFailed: number}} Write stats
 */
function writeAssessmentInformationToSheet(sheet, metadata) {
  const values = sheet.getDataRange().getValues();
  let totalRows = 0;
  let rowsUpdated = 0;

  for (let r = 0; r < values.length; r++) {
    const row = values[r];
    const labelColIndex = row.findIndex(
      (cellValue) => String(cellValue || "").trim() !== "",
    );

    if (labelColIndex === -1 || labelColIndex >= row.length - 1) {
      continue;
    }

    const rowLabel = String(row[labelColIndex] || "").trim();
    if (!rowLabel || shouldSkipAssessmentField(rowLabel)) {
      continue;
    }

    totalRows++;
    const match = findAssessmentEntryForLabel(rowLabel, metadata);
    if (!match) {
      continue;
    }

    sheet.getRange(r + 1, labelColIndex + 2).setValue(match.value);
    rowsUpdated++;
    Logger.log(
      `Assessment information matched row ${r + 1}: "${rowLabel}" -> "${match.label}"`,
    );
  }

  return {
    totalRows: totalRows,
    rowsUpdated: rowsUpdated,
    rowsFailed: totalRows - rowsUpdated,
  };
}

/*******************************************************
 * SHEET VALIDATION AND COLUMN MAPPING
 *******************************************************/

/**
 * Validates sheet has required columns and creates column index map
 * @param {GoogleAppsScript.Spreadsheet.Sheet} sheet - The active sheet
 * @returns {Object} Map of column names to column indices
 */
function validateAndMapColumns(sheet) {
  const allRows = sheet
    .getRange(1, 1, sheet.getLastRow(), sheet.getLastColumn())
    .getValues();

  // Find the header row by scanning for the Criteria column
  let headerRow = null;
  let headerRowIndex = -1;
  for (let r = 0; r < allRows.length; r++) {
    if (allRows[r].includes(CONFIG.COLUMN_NAMES.CRITERIA)) {
      headerRow = allRows[r];
      headerRowIndex = r + 1; // 1-based sheet row
      break;
    }
  }

  if (!headerRow) {
    throw new Error(
      `Could not find header row containing "${CONFIG.COLUMN_NAMES.CRITERIA}" in any row of the sheet.`,
    );
  }

  Logger.log(`Found header row at sheet row ${headerRowIndex}`);
  const columnMap = {};
  columnMap._headerRow = headerRowIndex; // Store for callers to use as data start reference

  // Optional columns (won't throw error if missing)
  const optionalColumns = [
    "AI_COMMENT",
    "CONFORMANCE_INTERPRETED",
    "APPLIES_TO_MEDIUMS",
    "INTERNAL_COMMENT",
  ];

  // Find each column
  for (const [key, columnName] of Object.entries(CONFIG.COLUMN_NAMES)) {
    const colIndex = headerRow.indexOf(columnName);
    if (colIndex === -1) {
      if (optionalColumns.includes(key)) {
        Logger.log(`Optional column "${columnName}" not found, skipping.`);
        continue;
      }
      throw new Error(
        `Required column "${columnName}" not found in sheet headers (checked row ${headerRowIndex}).`,
      );
    }
    columnMap[key] = colIndex + 1; // Convert to 1-based index
  }

  return columnMap;
}

/*******************************************************
 * CRITERIA EXTRACTION
 *******************************************************/

/**
 * Extracts criteria from sheet and creates a lookup map
 * @param {GoogleAppsScript.Spreadsheet.Sheet} sheet - The sheet
 * @param {Object} columnMap - Column index mapping
 * @param {number} startRow - Starting row number
 * @param {number} endRow - Ending row number
 * @returns {Map<string, number>} Map of normalized criteria to row numbers
 */
function getCriteriaFromSheet(sheet, columnMap, startRow, endRow) {
  const criteriaCol = columnMap.CRITERIA;
  const range = sheet.getRange(startRow, criteriaCol, endRow - startRow + 1, 1);
  const values = range.getValues();

  const criteriaMap = new Map();

  Logger.log(`=== GET CRITERIA FROM SHEET DEBUG ===`);
  Logger.log(`Criteria column: ${criteriaCol}`);
  Logger.log(`Row range: ${startRow} to ${endRow}`);

  values.forEach((row, index) => {
    const criteriaText = row[0];
    const normalizedKey = normalizeCriteriaKey(criteriaText);

    Logger.log(
      `Sheet row ${
        startRow + index
      }: "${criteriaText}" -> normalized key: "${normalizedKey}"`,
    );

    if (normalizedKey) {
      const rowNumber = startRow + index;
      criteriaMap.set(normalizedKey, rowNumber);
      Logger.log(`Added to map: "${normalizedKey}" -> row ${rowNumber}`);
    }
  });

  Logger.log(`=== CRITERIA MAP COMPLETE: ${criteriaMap.size} entries ===`);
  return criteriaMap;
}

/**
 * Normalizes criteria text to extract key (e.g., "1.1.1" from "1.1.1 Non-text Content")
 * @param {string} text - The criteria text
 * @returns {string|null} Normalized key or null
 */
function normalizeCriteriaKey(text) {
  if (!text) return null;

  const cleaned = String(text).replace(/\n/g, " ").replace(/\s+/g, " ").trim();

  // Extract numeric pattern like "1.1.1" or "4.1"
  const match = cleaned.match(/^[^\d]*([0-9]+\.[0-9]+(?:\.[0-9]+)*)/);

  return match ? match[1] : null;
}

/*******************************************************
 * DOCUMENT LOADING
 *******************************************************/

/**
 * Loads a Drive document and returns an opened Google Doc for downstream processing.
 * @param {string} fileId - Google Drive file ID
 * @returns {Object} Object containing DocumentApp.Document and optional tempDocId
 */
function openDocumentForProcessing(fileId) {
  let tempDocId = null;

  try {
    const file = DriveApp.getFileById(fileId);
    const mimeType = file.getMimeType();

    let docId = fileId;

    if (
      mimeType ===
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
    ) {
      Logger.log(`Converting DOCX to Google Doc: ${file.getName()}`);
      docId = convertDocxToGoogleDoc(file);
      tempDocId = docId;
    } else if (mimeType === "application/pdf") {
      Logger.log(`Converting PDF to Google Doc (with OCR): ${file.getName()}`);
      docId = convertPdfToGoogleDoc(file);
      tempDocId = docId;
    } else if (mimeType !== "application/vnd.google-apps.document") {
      throw new Error(
        `Unsupported file type: ${mimeType}. Please use Google Doc, DOCX, or PDF format.`,
      );
    }

    return {
      doc: DocumentApp.openById(docId),
      tempDocId: tempDocId,
    };
  } catch (error) {
    if (tempDocId) {
      cleanupTempDoc(tempDocId);
    }
    throw new Error(`Failed to load document: ${error.message}`);
  }
}

/**
 * Loads document from Drive and extracts tables
 * Handles Google Docs, DOCX, and PDF files (auto-converts as needed)
 * @param {string} fileId - Google Drive file ID
 * @returns {Object} Object containing tables array, document, and optional tempDocId
 */
function loadDocument(fileId) {
  try {
    const documentData = openDocumentForProcessing(fileId);
    const tables = documentData.doc.getBody().getTables();

    if (!tables || tables.length === 0) {
      cleanup(documentData.tempDocId);
      throw new Error(
        "No tables found in document. Please check document structure.",
      );
    }

    return {
      doc: documentData.doc,
      tables: tables,
      tempDocId: documentData.tempDocId,
    };
  } catch (error) {
    throw error;
  }
}

/**
 * Converts DOCX file to Google Doc format
 * @param {GoogleAppsScript.Drive.File} file - The DOCX file
 * @returns {string} ID of converted Google Doc
 */
function convertDocxToGoogleDoc(file) {
  showProgress("Converting DOCX to Google Doc...");
  const blob = file.getBlob();

  const converted = Drive.Files.create(
    {
      name: `[Temp VPAT] ${file.getName()} ${new Date().toISOString()}`,
      mimeType: "application/vnd.google-apps.document",
    },
    blob,
  );

  // Wait a moment for conversion to complete
  Utilities.sleep(2000);
  Logger.log(`DOCX converted to Google Doc with ID: ${converted.id}`);
  return converted.id;
}

/**
 * Converts PDF file to Google Doc format with OCR
 * @param {GoogleAppsScript.Drive.File} file - The PDF file
 * @returns {string} ID of converted Google Doc
 */
function convertPdfToGoogleDoc(file) {
  showProgress("Converting PDF to Google Doc (this may take a moment)...");
  const blob = file.getBlob();

  // Convert PDF to Google Doc with OCR enabled
  const converted = Drive.Files.create(
    {
      name: `[Temp VPAT] ${file.getName()} ${new Date().toISOString()}`,
      mimeType: "application/vnd.google-apps.document",
    },
    blob,
    {
      ocrLanguage: "en", // OCR is automatically applied when converting PDF to Doc
    },
  );

  // Wait longer for PDF conversion (OCR takes time)
  showProgress("Waiting for PDF conversion to complete...");
  Utilities.sleep(5000);
  Logger.log(`PDF converted to Google Doc with ID: ${converted.id}`);
  return converted.id;
}

/*******************************************************
 * VPAT DATA EXTRACTION
 *******************************************************/

/**
 * Extracts VPAT data from document tables
 * @param {GoogleAppsScript.Document.Table[]} tables - Array of tables from document
 * @param {Map<string, number>} criteriaMap - Map of criteria to row numbers
 * @returns {Object} Map of row numbers to VPAT data
 */
function extractVPATData(tables, criteriaMap) {
  const vpatData = {};
  let rowsProcessed = 0;

  Logger.log(`=== EXTRACT VPAT DATA DEBUG ===`);
  Logger.log(`Number of tables: ${tables.length}`);
  Logger.log(`Criteria map size: ${criteriaMap.size}`);
  Logger.log(
    `Criteria keys in map: ${Array.from(criteriaMap.keys()).join(", ")}`,
  );

  for (const table of tables) {
    const numRows = table.getNumRows();
    Logger.log(`Processing table with ${numRows} rows`);

    // Skip header row (start from index 1)
    for (let i = 1; i < numRows; i++) {
      try {
        const row = table.getRow(i);

        // Ensure row has expected number of columns
        if (row.getNumCells() < CONFIG.EXPECTED_TABLE_COLUMNS) {
          Logger.log(
            `Row ${i} has ${row.getNumCells()} cells, expected ${
              CONFIG.EXPECTED_TABLE_COLUMNS
            }, skipping`,
          );
          continue;
        }

        // Extract cell data
        const criteriaText = getCellText(row.getCell(0));
        const conformanceText = getCellText(row.getCell(1));
        const remarksText = getCellText(row.getCell(2));

        // Normalize criteria and find matching row
        const criteriaKey = normalizeCriteriaKey(criteriaText);

        Logger.log(
          `Table row ${i}: criteria="${criteriaText}" -> key="${criteriaKey}"`,
        );

        if (criteriaKey && criteriaMap.has(criteriaKey)) {
          const targetRow = criteriaMap.get(criteriaKey);

          vpatData[targetRow] = {
            conformanceLevel: conformanceText,
            remarks: remarksText,
            originalCriteria: criteriaText,
          };

          Logger.log(
            `✓ Matched! Writing to sheet row ${targetRow}: conformance="${conformanceText}"`,
          );
          rowsProcessed++;
        } else {
          Logger.log(`✗ No match in criteria map for key "${criteriaKey}"`);
        }
      } catch (error) {
        Logger.log(`Error processing table row ${i}: ${error.message}`);
        // Continue processing other rows
      }
    }
  }

  Logger.log(`=== EXTRACTION COMPLETE: ${rowsProcessed} criteria matched ===`);
  return vpatData;
}

/**
 * Safely extracts text from a table cell
 * @param {GoogleAppsScript.Document.TableCell} cell - The table cell
 * @returns {string} Cell text content
 */
function getCellText(cell) {
  try {
    return cell.getText().trim();
  } catch (error) {
    Logger.log(`Error reading cell text: ${error.message}`);
    return "";
  }
}

/*******************************************************
 * SHEET WRITING
 *******************************************************/

/**
 * Writes extracted VPAT data to sheet
 * @param {GoogleAppsScript.Spreadsheet.Sheet} sheet - The target sheet
 * @param {Object} vpatData - Map of row numbers to VPAT data
 * @param {Object} columnMap - Column index mapping
 * @returns {Object} Processing results statistics
 */
function writeDataToSheet(sheet, vpatData, columnMap) {
  let rowsUpdated = 0;

  const sortedRows = Object.keys(vpatData)
    .map((r) => parseInt(r, 10))
    .sort((a, b) => a - b);

  Logger.log(`=== WRITE DATA TO SHEET DEBUG ===`);
  Logger.log(`Total rows to write: ${sortedRows.length}`);
  Logger.log(`vpatData keys: ${Object.keys(vpatData).join(", ")}`);
  Logger.log(`Column map CONFORMANCE_LEVEL: ${columnMap.CONFORMANCE_LEVEL}`);
  Logger.log(`Column map REMARKS: ${columnMap.REMARKS}`);

  for (const rowNum of sortedRows) {
    try {
      const data = vpatData[rowNum];
      Logger.log(
        `Writing row ${rowNum}: Conformance="${
          data.conformanceLevel
        }", Remarks="${data.remarks.substring(0, 50)}..."`,
      );

      // Write conformance level
      sheet
        .getRange(rowNum, columnMap.CONFORMANCE_LEVEL)
        .setValue(data.conformanceLevel);

      // Write remarks
      sheet.getRange(rowNum, columnMap.REMARKS).setValue(data.remarks);

      rowsUpdated++;
      Logger.log(`Successfully wrote row ${rowNum}`);
    } catch (error) {
      Logger.log(`Error writing data to row ${rowNum}: ${error.message}`);
      Logger.log(`Error stack: ${error.stack}`);
    }
  }

  Logger.log(`=== WRITE COMPLETE: ${rowsUpdated} rows updated ===`);

  return {
    totalRows: sortedRows.length,
    rowsUpdated: rowsUpdated,
    rowsFailed: sortedRows.length - rowsUpdated,
  };
}

