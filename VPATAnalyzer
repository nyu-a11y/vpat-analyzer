/**
 * Runs both extraction and interpretation in sequence
 */
function runFullProcessing() {
  const extractionResult = processVPATDocument();
  if (!extractionResult || !extractionResult.success) {
    return extractionResult;
  }

  // Small delay between operations
  Utilities.sleep(2000);
  return interpretConformanceLevels();
}

/**
 * Runs all three processes: extraction, interpretation, and quality analysis
 * This function can be assigned to a button in Google Sheets
 */
function runFullProcessingWithQuality() {
  const extractionResult = processVPATDocument();
  if (!extractionResult || !extractionResult.success) {
    return extractionResult;
  }

  Utilities.sleep(2000);
  const interpretationResult = interpretConformanceLevels();
  if (!interpretationResult || !interpretationResult.success) {
    return interpretationResult;
  }

  Utilities.sleep(2000);
  return analyzeQualityChecklist();
}

/**
 * Button-friendly version: Runs complete VPAT processing pipeline
 * Assign this function to a button for one-click processing
 * Processes: 1) Assessment info, 2) Extract data, 3) Interpret with AI, 4) Quality analysis
 *
 * TO ASSIGN TO A BUTTON:
 * 1. Insert > Drawing (create a button/shape)
 * 2. Click the three dots > Assign script
 * 3. Enter: runCompleteAnalysis
 */
/**
 * Unhides all five working sheets so they are visible before any operation runs.
 * Safe to call even if a sheet is already visible.
 */
function unhideAllSheets() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheetNames = [
    CONFIG.START_SHEET_NAME,
    CONFIG.ASSESSMENT_SHEET_NAME,
    CONFIG.OUTPUT_SHEET_NAME,
    CONFIG.QUALITY_CHECKLIST.SHEET_NAME,
    CONFIG.SCORING_SHEET_NAME,
  ];
  for (const name of sheetNames) {
    const sheet = ss.getSheetByName(name);
    if (sheet && sheet.isSheetHidden()) {
      sheet.showSheet();
    }
  }
}

function runCompleteAnalysis() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  unhideAllSheets();

  try {
    const userConfig = getUserInput();

    // Show starting message
    ss.toast("Starting complete VPAT analysis...", "Processing", 5);

    // Step 1: Fill Assessment Information
    ss.toast(
      "Step 1/4: Filling assessment information...",
      "Processing",
      -1,
    );
    const assessmentResult = processAssessmentInformation(userConfig.fileId);
    if (!assessmentResult || !assessmentResult.success) {
      return;
    }
    Utilities.sleep(2000);

    // Step 2: Extract from VPAT document
    ss.toast(
      "Step 2/4: Extracting data from VPAT document...",
      "Processing",
      -1,
    );
    const extractionResult = processVPATDocument(userConfig);
    if (!extractionResult || !extractionResult.success) {
      return;
    }
    Utilities.sleep(2000);

    // Step 3: AI interpretation
    ss.toast("Step 3/4: Running AI interpretation...", "Processing", -1);
    const interpretationResult = interpretConformanceLevels(true); // Skip prompt in automated mode
    if (!interpretationResult || !interpretationResult.success) {
      return;
    }
    Utilities.sleep(2000);

    // Step 4: Quality checklist analysis
    ss.toast("Step 4/4: Analyzing quality requirements...", "Processing", -1);
    const qualityResult = analyzeQualityChecklist();
    if (!qualityResult || !qualityResult.success) {
      return;
    }

    // Success message
    ss.toast("✓ Complete analysis finished successfully!", "Success", 10);
  } catch (error) {
    Logger.log(`Error in runCompleteAnalysis: ${error.message}`);
    Logger.log(error.stack);
    ss.toast(`Error: ${error.message}`, "Analysis Failed", 10);
  }
}

