/**
 * Groups requirements by their Category column value.
 * Each unique category becomes one batch group sent to the AI together.
 * Preserves the original row order within each category.
 * @param {Array} requirements
 * @returns {Array} Array of { criteriaNum: string, requirements: Array }
 */
function groupRequirementsByCriteria(requirements) {
  const categoryMap = new Map();

  for (const req of requirements) {
    const category = req.category || "Uncategorized";
    if (!categoryMap.has(category)) {
      categoryMap.set(category, []);
    }
    categoryMap.get(category).push(req);
  }

  const groups = Array.from(categoryMap.entries()).map(([category, reqs]) => ({
    criteriaNum: category,
    requirements: reqs,
  }));

  Logger.log(`Created ${groups.length} category groups`);
  groups.forEach((g) => {
    Logger.log(
      `  Category "${g.criteriaNum}": ${g.requirements.length} requirements`,
    );
  });

  return groups;
}

/**
 * Extracts full text from VPAT document for analysis
 */
function extractFullDocumentText(fileId) {
  const documentData = loadDocument(fileId);

  try {
    const doc = DocumentApp.openById(documentData.tempDocId || fileId);
    const body = doc.getBody();
    let fullText = body.getText();

    // Truncate if too long
    const maxLength = CONFIG.QUALITY_CHECKLIST.MAX_DOC_LENGTH;
    if (fullText.length > maxLength) {
      Logger.log(
        `Document truncated from ${fullText.length} to ${maxLength} characters`,
      );
      fullText =
        fullText.substring(0, maxLength) +
        "\n\n[Document truncated for analysis...]";
    }

    // Cleanup temp doc if created
    if (documentData.tempDocId) {
      cleanup(documentData.tempDocId);
    }

    return fullText;
  } catch (error) {
    if (documentData.tempDocId) {
      cleanup(documentData.tempDocId);
    }
    throw error;
  }
}

